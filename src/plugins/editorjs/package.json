{
  "name": "editorjs",
  "version": "1.0.0",
  "private": true,
  "description": "Editor.js custom field for Strapi 5",
  "strapi": {
    "name": "editorjs",
    "description": "Editor.js rich text editor custom field",
    "kind": "plugin",
    "displayName": "Editor.js"
  },
  "exports": {
    "./strapi-server": "./server/src/index.js",
    "./strapi-admin": {
      "source": "./admin/src/index.ts",
      "import": "./admin/src/index.ts",
      "require": "./admin/src/index.ts",
      "default": "./admin/src/index.ts"
    }
  },
  "dependencies": {
    "@editorjs/editorjs": "^2.30.0",
    "@editorjs/header": "^2.8.0",
    "@editorjs/list": "^2.0.0",
    "@editorjs/paragraph": "^2.11.0",
    "@editorjs/image": "^2.10.0",
    "@editorjs/embed": "^2.7.0",
    "@editorjs/table": "^2.4.0",
    "@editorjs/quote": "^2.7.0",
    "@editorjs/delimiter": "^1.4.0",
    "@editorjs/code": "^2.9.0",
    "@editorjs/checklist": "^1.6.0",
    "@editorjs/marker": "^1.4.0",
    "@editorjs/inline-code": "^1.5.0",
    "@editorjs/link": "^2.6.0",
    "@editorjs/warning": "^1.4.0"
  }
}
